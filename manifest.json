{
  "manifest_version": 3,
  "name": "PSA Time Filler",
  "version": "1.0",
  "description": "Remplit automatiquement les feuilles de temps PSA",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://psa-fs.ent.cgi.com/psc/fsprda/EMPLOYEE/ERP/c/*"
      ],
      "js": [
        "content/dom-utils.js",
        "content/row-resolver.js",
        "content/fill-hours.js",
        "content/fill-rest.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "resources/config.json",
        "resources/default_profile.json",
        "resources/triggerClickFunction.js"
      ],
      "matches": [
        "https://psa-fs.ent.cgi.com/*"
      ]
    }
  ]
}