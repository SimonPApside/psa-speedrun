{
  "manifest_version": 3,
  "name": "PSA Time Filler",
  "version": "1.0",
  "description": "Remplit automatiquement les feuilles de temps PSA de façon rapide",
  "icons": {
     "16": "icons/favicon-16x16.png",
     "32": "icons/favicon-32x32.png",
     "48": "icons/favicon-48x48.png",
     "128": "icons/favicon-128x128.png"
   },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "notifications",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Open PSA Time Filler",
    "default_icon": {
      "16": "icons/favicon-16x16.png",
      "32": "icons/favicon-32x32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://psa-fs.ent.cgi.com/psc/fsprda/EMPLOYEE/ERP/c/*"
      ],
      "js": [
        "content/dom-utils.js",
        "content/row-resolver.js",
        "content/fill-hours.js",
        "content/fill-rest.js",
        "content.js",
        "content/fab.js"
      ],
      "css": [
        "content/fab.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "resources/config.json",
        "resources/default_profile.json",
        "resources/triggerClickFunction.js",
        "icons/favicon-48x48.png"
      ],
      "matches": [
        "https://psa-fs.ent.cgi.com/*"
      ]
    }
  ]
}